<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.travory.app.user.mapper.UserMapper">

    <insert id="insertUser">
        INSERT INTO users
        (
            user_id,
            password,
            user_name,
            gender,
            phone_number,
            profile_image,
            email
        )
        VALUES
            (
                #{userId},
                #{password},
                #{userName},
                #{gender},
                #{phoneNumber},
                #{profileImage},
                #{email}
            )
    </insert>

    <select id="findByUserId"
            resultType="com.travory.app.user.dto.UserDto">
        SELECT *
        FROM users
        WHERE user_id = #{userId}
    </select>

    <select id="findById"
            resultType="com.travory.app.user.dto.UserDto">
        SELECT *
        FROM users
        WHERE id = #{id}
    </select>

    <select id="findByEmail"
            resultType="com.travory.app.user.dto.UserDto">
        SELECT *
        FROM users
        WHERE email = #{email}
    </select>

    <update id="updateProfile">
        UPDATE users
        SET
            bio = #{bio},
            travel_style = #{travelStyle},
            favorite_country = #{favoriteCountry},
            profile_image = #{profileImage}
        WHERE id = #{id}
    </update>

</mapper>
